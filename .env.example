# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Django core
SECRET_KEY=replace-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_PASSWORD=replace-with-db-password
USE_PGBOUNCER=False

# Redis (cache + Celery broker/result backend)
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_RESULT_URL=redis://127.0.0.1:6379/2

# Production hardening flag (True enables HSTS, SSL redirect, S3 storage, etc.)
USE_SECURE_PROXY=False

# AWS S3 (only read when USE_SECURE_PROXY=True)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Google OAuth — currently configured via Django admin (allauth SocialApp).
# Kept here for reference / future env-based wiring.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# OpenAI Content Moderation (posts & comments) — omni-moderation-latest
OPENAI_API_KEY=sk-your-openai-api-key-here
MODERATION_FAIL_OPEN=True

